{
  "compilerOptions": {
    "strict": true,
    "target": "es2015",
    "module": "es2022",
    "lib": [
      "es2018",
      "dom"
    ],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "source"
  ]
}
